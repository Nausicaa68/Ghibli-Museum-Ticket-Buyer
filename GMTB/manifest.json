{
  "manifest_version": 2,
  "name": "Ghibli Museum Ticket Buyer",
  "version": "3.3",
  "description": "Open ticket pages in multiple Firefox containers, monitor Queue-it positions, and auto-fill saved ticket information.",
  "permissions": [
    "tabs",
    "contextualIdentities",
    "cookies",
    "storage",
    "notifications",
    "https://l-tike.com/*",
    "https://*.queue-it.net/*",
    "https://service5.cacs.jp/*"
  ],
  "browser_action": {
    "default_title": "Ghibli Museum Ticket Buyer",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "assets/logo.png"
    }
  },
  "icons": {
    "48": "assets/logo.png"
  },
  "options_ui": {
    "page": "personal-info.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.queue-it.net/*",
        "https://l-tike.com/*",
        "https://service5.cacs.jp/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
